# ============================================================
#  Nannies Child Care — Plantilla de variables de entorno
#  Copiar a `.env` y rellenar. El `.env` real NUNCA se sube.
#  (SEGURIDAD §6: secretos fuera del código)
# ============================================================

# --- Base de datos (Postgres autohospedado en VPS; no expuesta a internet) ---
DATABASE_URL="postgresql://USUARIO:CONTRASENA@localhost:5432/nannies?schema=public"

# --- Autenticación (auth propia NestJS) ---
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="CAMBIAR-por-secreto-largo-aleatorio"
JWT_EXPIRES_IN="8h"
# Cookies httpOnly seguras (SEGURIDAD §4)
COOKIE_SECRET="CAMBIAR-por-otro-secreto-aleatorio"

# --- Servidor ---
NODE_ENV="development"
API_PORT="3001"
# CORS restrictivo: solo el dominio del sistema (SEGURIDAD §10)
CORS_ORIGIN="http://localhost:3000"

# --- Google Forms → M5 (se cablea al construir M5; resguardado como secreto) ---
# GOOGLE_SERVICE_ACCOUNT_JSON="/ruta/segura/fuera/del/repo/credenciales.json"
# GOOGLE_FORMS_SHEET_ID=""

# --- Rate limiting (SEGURIDAD §4 y §8: frena fuerza bruta y protege el vCPU único) ---
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"
