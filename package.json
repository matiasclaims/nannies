{
  "name": "nannies-child-care",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema Operativo Integral · Nannies Child Care — monorepo (API NestJS + Web React). Construcción módulo por módulo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "api:dev": "npm run start:dev --workspace apps/api",
    "web:dev": "npm run dev --workspace apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "audit": "npm audit --audit-level=high"
  }
}
